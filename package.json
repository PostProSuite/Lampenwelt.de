{
  "name": "PostProSuite",
  "version": "1.2.22",
  "description": "PostPro Suite - Professional Image Processing Workflow",
  "main": "main.js",
  "homepage": "./",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "rm -rf dist && electron-builder && bash scripts/remove-codesign.sh",
    "delta": "node build-delta-updates.js",
    "build-release": "npm run build && npm run delta",
    "release": "npm run build-release -- --publish always",
    "postrelease": "rm -rf dist node_modules && gh release list --repo PostProSuite/Lampenwelt.de --limit 50 --json tagName --jq '.[1:][].tagName' | xargs -I{} gh release delete {} --repo PostProSuite/Lampenwelt.de --yes --cleanup-tag"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PostProSuite/Lampenwelt.de.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/PostProSuite/Lampenwelt.de/issues"
  },
  "build": {
    "appId": "com.postprosuite.app",
    "productName": "PostPro Suite",
    "files": [
      "main.js",
      "server.js",
      "installer.js",
      "preload.js",
      "lib/**/*",
      "node_modules/**/*",
      "src/**/*",
      "public/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "src/**/*"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.business",
      "icon": "assets/icon.icns",
      "artifactName": "PostPro-Suite-${version}-${arch}-mac.${ext}",
      "sign": null,
      "gatekeeperAssess": false,
      "hardenedRuntime": false,
      "requirements": null
    },
    "dmg": {
      "sign": false,
      "artifactName": "PostPro-Suite-${version}-${arch}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "PostProSuite",
      "repo": "Lampenwelt.de",
      "releaseType": "release"
    }
  },
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^3.0.1"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "express-session": "^1.19.0"
  }
}
